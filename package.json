{
  "name": "evernear",
  "version": "0.3.0",
  "private": true,
  "description": "Local-first writing workspace for Evernear.",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\" \"npm:dev:app\"",
    "dev:renderer": "vite",
    "dev:electron": "tsup src/main/index.ts src/preload/index.ts --format cjs --out-dir dist-electron --watch --external electron",
    "dev:app": "wait-on tcp:5173 file:dist-electron/main/index.js file:dist-electron/preload/index.js && cross-env EVERNEAR_RENDERER_URL=http://127.0.0.1:5173 electron dist-electron/main/index.js",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsup src/main/index.ts src/preload/index.ts --format cjs --out-dir dist-electron --external electron",
    "start": "electron dist-electron/main/index.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run rebuild:node && vitest run && npm run rebuild:native",
    "test:only": "vitest run",
    "test:watch": "npm run rebuild:node && vitest",
    "test:ui": "npm run rebuild:node && vitest --ui",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "rebuild:node": "npm rebuild better-sqlite3 --no-save",
    "postinstall": "npm run rebuild:native"
  },
  "dependencies": {
    "@chenglou/pretext": "0.0.5",
    "@vitejs/plugin-react": "6.0.1",
    "better-sqlite3": "12.9.0",
    "electron": "41.2.1",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.4",
    "prosemirror-schema-basic": "1.2.4",
    "prosemirror-state": "1.4.4",
    "prosemirror-transform": "1.12.0",
    "prosemirror-view": "1.41.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "8.0.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electron/rebuild": "4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "25.6.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitest/ui": "^4.1.4",
    "concurrently": "9.2.1",
    "cross-env": "10.1.0",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4",
    "wait-on": "9.0.5"
  }
}
